# FastAPI Configuration
ENVIRONMENT=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aionforge_revenue_os
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Gumroad API
GUMROAD_API_KEY=your-gumroad-api-key
GUMROAD_WEBHOOK_SECRET=your-webhook-secret

# Notion API
NOTION_API_KEY=your-notion-api-key
NOTION_DATABASE_ID=your-database-id

# Email Service (SendGrid or Mailgun)
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@aionforge.com
EMAIL_FROM_NAME=AIONForge

# Stripe (optional payment processing)
STRIPE_API_KEY=your-stripe-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Logging
LOG_LEVEL=INFO
